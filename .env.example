DATABASE_PASSWORD=use_unique_long_string_there
PGADMIN_DATABASE_PASSWORD=use_another_unique_long_string_here
OPENPROJECT_DATABASE_PASSWORD=use_one_more_unique_long_string_here
OPENPROJECT_SECRET_KEY_BASE=a_unique_and_long_base_to_sign_cookies
POSTGREST_JWT_SECTET=use_the_third_unique_long_string_here
HERMES_API_KEY=use_a_long_string_here_as_well
API_KEY=generate_this_with_shell_script
NEXTCLOUD_DATABASE_PASSWORD=and_one_more_unique_long_password
NEXTCLOUD_REDIS_PASSWORD=another_long_and_unique_long_string_here

# pgAdmin entrypoint requires these to be set, but actual login uses
# webserver auth (X-Authentication-Email header) — values are unused.
PGADMIN_DEFAULT_EMAIL=user@nocodenation.org
PGADMIN_DEFAULT_PASSWORD=unused_pgadmin_uses_webserver_auth

# OpenCode (web UI on http://localhost:8103)
# Bare model name is treated as an ollama model; use provider/model (e.g.
# anthropic/claude-sonnet-4-6) to pick a non-ollama provider.
OPENCODE_MODEL=qwen35-122b
# Provide one or more API keys to enable providers
OPENCODE_ANTHROPIC_KEY=
OPENCODE_OPENAI_KEY=
# Ollama base URL. The hostname (e.g. dgx_spark) is resolved via compose
# extra_hosts using OPENCODE_OLLAMA_HOST_IP.
OPENCODE_OLLAMA_HOST=http://dgx_spark:8800
OPENCODE_OLLAMA_HOST_IP=100.106.155.121
# Text-embedding model (OpenAI-compatible /v1/embeddings API). The hostname
# (embedding_host) is resolved via compose extra_hosts using
# OPENCODE_EMBEDDING_HOST_IP — point it at whichever server runs the model.
OPENCODE_EMBEDDING_HOST=http://embedding_host:8801
OPENCODE_EMBEDDING_HOST_IP=100.106.155.121
OPENCODE_EMBEDDING_MODEL=llama-embed-nemotron-8b
# Request timeout in ms (default 21600000 = 6 hrs). Increase for large/slow models.
OPENCODE_TIMEOUT=21600000
# Max ms between streamed chunks before aborting (default 3600000 = 1 hr).
OPENCODE_CHUNK_TIMEOUT=3600000





# =============================================================================
# BUILD CONFIGURATION (used by build.sh)
# =============================================================================

# SYSTEM_DEPENDENCIES
# -------------------
# A comma-separated list of apt packages to install in the Docker image.
# These are system libraries that might be required for certain Python packages
# to work properly (not Python packages themselves - those are managed by NiFi).
#
# Example: Install Tesseract OCR and related libraries
# SYSTEM_DEPENDENCIES="tesseract-ocr, tesseract-ocr-eng, libtesseract-dev, libleptonica-dev, pkg-config"
#
# Example: Install multiple system packages
# SYSTEM_DEPENDENCIES="poppler-utils, libgl1, ffmpeg"
#
# Default: empty (no additional packages)
SYSTEM_DEPENDENCIES=""

# POST_INSTALLATION_COMMANDS
# --------------------------
# A comma-separated list of shell commands to run after package installation.
# Useful for installing additional tools or configuring the environment.
#
# Example: Install Playwright dependencies
# POST_INSTALLATION_COMMANDS="playwright install-deps"
#
# Example: Install Bun runtime
# POST_INSTALLATION_COMMANDS="curl -fsSL https://bun.sh/install | bash, cp /root/.bun/bin/bun /usr/local/bin/bun, chmod +x /usr/local/bin/bun"
#
# Example: Multiple commands
# POST_INSTALLATION_COMMANDS="playwright install-deps, ls -la /"
#
# Default: empty (no post-installation commands)
POST_INSTALLATION_COMMANDS=""
# -------------
# The username for NiFi authentication.
# Must be provided together with NIFI_PASSWORD to take effect.
# If not set, NiFi will generate a random username on startup.
#
# Example:
# NIFI_USERNAME="admin"
#
# Default: empty (NiFi generates random username)
NIFI_USERNAME="liquid-user"

# NIFI_PASSWORD
# -------------
# The password for NiFi authentication.
# Must be at least 12 characters long.
# Must be provided together with NIFI_USERNAME to take effect.
# If not set, NiFi will generate a random password on startup.
#
# Example:
# NIFI_PASSWORD="mysecurepassword123"
#
# Default: empty (NiFi generates random password)
NIFI_PASSWORD="liquid-user-password"
