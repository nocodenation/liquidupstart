# =============================================================================
# All-In-Wonder — environment configuration
# =============================================================================
# Copy this file to .env and fill in the values. Variables are grouped by area:
#   1. Networking ............ published host ports
#   2. Service secrets ....... database passwords, tokens, logins (per service)
#   3. LLM provider API keys . shared across OpenCode / OpenClaw / Hermes
#   4. AI service config ..... OpenCode & OpenClaw model/endpoint settings
#   5. NiFi authentication ... NiFi login + keystore
#   6. Image build config .... knobs for build.sh
#
# Use long, unique, random strings for every secret in section 2.
# =============================================================================


# =============================================================================
# 1. NETWORKING
# =============================================================================
# Host ports published by the nginx proxy. Service UIs are reached as
# <name>.localhost:${SYSTEM_HTTP_PORT} (and https on ${SYSTEM_HTTPS_PORT}).
SYSTEM_HTTP_PORT=
SYSTEM_HTTPS_PORT=


# =============================================================================
# 2. SERVICE SECRETS & CREDENTIALS - AUTOGENERATED ONCE IF VALUES ARE EMPTY
# =============================================================================

# Unique id of this installation: the timestamp (YYYYMMDDHHMMSS) of when this
# .env was created. It is appended to every container name ("<name>-${APP_ID}")
# so multiple checkouts can run side by side. Leave empty - filled in
# automatically.
APP_ID=

# --- PostgreSQL + PostgREST (main app database & REST API) ---
DATABASE_PASSWORD=
# PostgREST JWT signing secret. NOTE: the name is misspelled "SECTET" — but
# compose.yml references the same spelling, so do not rename one without the
# other.
POSTGREST_JWT_SECTET=

# --- pgAdmin ---
PGADMIN_DATABASE_PASSWORD=

# --- OpenProject ---
OPENPROJECT_DATABASE_PASSWORD=
OPENPROJECT_SECRET_KEY_BASE=

# --- NextCloud ---
NEXTCLOUD_DATABASE_PASSWORD=
NEXTCLOUD_REDIS_PASSWORD=

# --- Hermes (agent API + webhook token) ---
HERMES_API_KEY=

# --- OpenClaw (gateway token) ---
OPENCLAW_GATEWAY_TOKEN=


# =============================================================================
# 3. SERVICE SECRETS & CREDENTIALS - USER CAN CHANGE ON FIRST RUN
# =============================================================================
# The pgAdmin entrypoint requires these, but login actually uses webserver auth
# (X-Authentication-Email header) — the values below are unused at login.
PGADMIN_DEFAULT_EMAIL=user@nocodenation.org


# =============================================================================
# 4. SERVICE SECRETS & CREDENTIALS - SCRIPTS GENERATE IT - DO NOT SHOW UI
# =============================================================================
# Bearer token for the PostgREST API. Generated by
# config/scripts/start/generate_api_key.sh on startup — leave the placeholder.
API_KEY=generate_this_with_shell_script

# The pgAdmin entrypoint requires these, but login actually uses webserver auth
# (X-Authentication-Email header) — the values below are unused at login.
PGADMIN_DEFAULT_PASSWORD=unused_pgadmin_uses_webserver_auth


# =============================================================================
# 5. LLM PROVIDER API KEYS (shared)
# =============================================================================
# Provider credentials consumed by the AI services. Leave a key blank to leave
# that provider disabled. How they reach each service:
#   - OpenCode reads them directly — compose passes them into the container and
#     config/opencode/entrypoint.sh turns each non-empty key into a provider.
#   - OpenClaw & Hermes have them rendered into their own .env at start, but ONLY
#     the keys their env_template declares
#     (config/scripts/start/{openclaw,hermes}.sh).
#
# Support matrix (✓ = the service can use this key, – = not supported there):
#                        OpenCode  OpenClaw  Hermes
#   ANTHROPIC_API_KEY       ✓         ✓         –
#   OPENAI_API_KEY          ✓         ✓         –
#   OPENROUTER_API_KEY      ✓         ✓         ✓
#   GOOGLE_API_KEY          ✓         ✓         ✓
#   GEMINI_API_KEY          ✓         ✓         ✓
#   MINIMAX_API_KEY         ✓         ✓         ✓
#   ZAI_API_KEY             ✓         ✓         –
#   AI_GATEWAY_API_KEY      ✓         ✓         –   (Vercel AI Gateway)
#   SYNTHETIC_API_KEY       ✓         ✓         –
#   TOKENHUB_API_KEY        –         ✓         –
#   LKEAP_API_KEY           –         ✓         –
#   COPILOT_GITHUB_TOKEN    –         ✓         –   (GitHub Copilot, native provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
ZAI_API_KEY=
AI_GATEWAY_API_KEY=
SYNTHETIC_API_KEY=
TOKENHUB_API_KEY=
LKEAP_API_KEY=
COPILOT_GITHUB_TOKEN=


# =============================================================================
# 6. OPENCLAW CONFIGURATION
# =============================================================================

# --- OpenClaw (agent gateway) ---
# Primary model for OpenClaw agents (provider/model, routed via section 5 keys).
# Ignored when OPENCLAW_ENABLE_CLAUDE_CLI=1 or OPENCLAW_ENABLE_COPILOT=1.
# Precedence if more than one is set: claude-cli > copilot > this.
OPENCLAW_PRIMARY_MODEL=openrouter/anthropic/claude-opus-4.8

# --- OpenClaw (claude code backend) ---
# Install the Claude Code CLI into the OpenClaw image (build) and route LLM
# requests through it (start). When installed, OPENCLAW_PRIMARY_MODEL is ignored
# and OPENCLAW_CLAUDE_CLI_MODEL is used via the claude-cli runtime.
OPENCLAW_ENABLE_CLAUDE_CLI=0
# Claude model the CLI backend runs when OPENCLAW_ENABLE_CLAUDE_CLI=1 (must be a
# model your Claude Code login can access).
OPENCLAW_CLAUDE_CLI_MODEL=anthropic/claude-opus-4-8

# --- OpenClaw (GitHub Copilot backend) ---
# Use GitHub Copilot as OpenClaw's provider. When 1, OPENCLAW_PRIMARY_MODEL is
# ignored and OPENCLAW_COPILOT_MODEL is used as the primary; github-copilot/* is
# added to the model picker so you can switch to any Copilot model your plan
# offers. Auth: sign in at first start (device flow), or set COPILOT_GITHUB_TOKEN
# in section 5 (a gho_/ghu_ OAuth token — NOT a PAT) for headless auth.
OPENCLAW_ENABLE_COPILOT=0
# Primary Copilot model when OPENCLAW_ENABLE_COPILOT=1 (availability depends on
# your Copilot plan; switch any time in the model picker).
OPENCLAW_COPILOT_MODEL=github-copilot/claude-sonnet-4.6


# =============================================================================
# 7. OPENCODE CONFIGURATION
# =============================================================================

# --- OpenCode (coding-agent web UI) ---
# A bare model name is treated as an Ollama model; use provider/model (e.g.
# anthropic/claude-sonnet-4-6, openrouter/..., google/gemini-...) to select a
# non-Ollama provider configured from the keys in section 3.
OPENCODE_MODEL=qwen35-122b
# Ollama base URL. The hostname (e.g. dgx_spark) is resolved via compose
# extra_hosts using OPENCODE_OLLAMA_HOST_IP.
OPENCODE_OLLAMA_HOST=
OPENCODE_OLLAMA_HOST_IP=
# Text-embedding model (OpenAI-compatible /v1/embeddings API). The hostname
# (embedding_host) is resolved via compose extra_hosts using
# OPENCODE_EMBEDDING_HOST_IP — point it at whichever server runs the model.
OPENCODE_EMBEDDING_HOST=
OPENCODE_EMBEDDING_HOST_IP=
OPENCODE_EMBEDDING_MODEL=
# Request timeout in ms (default 21600000 = 6 hrs). Increase for large/slow models.
OPENCODE_TIMEOUT=21600000
# Max ms between streamed chunks before aborting (default 3600000 = 1 hr).
OPENCODE_CHUNK_TIMEOUT=3600000


# =============================================================================
# 8. NiFi AUTHENTICATION
# =============================================================================
# NIFI_USERNAME and NIFI_PASSWORD must be provided together to take effect; if
# left unset, NiFi generates random credentials on startup. The password must be
# at least 12 characters long.
NIFI_USERNAME="nifi"
NIFI_PASSWORD="nifipassword"
# Keystore password for the HTTPS processors' TLS keystore/truststore.
NIFI_KEYSTORE_PASSWORD=keystorepassword


# =============================================================================
# 9. IMAGE BUILD CONFIGURATION (used by build.sh)
# =============================================================================
#
# These settings customize the Docker images built by build.sh for the four
# buildable services: NiFi, OpenCode, OpenClaw and Hermes. Each image is
# rendered from a template Dockerfile at build time, injecting:
#   - extra apt packages  (SYSTEM_DEPENDENCIES)
#   - shell commands run after the package install  (POST_INSTALLATION_COMMANDS)
#
# There are two layers:
#   1. The GENERIC settings below (SYSTEM_DEPENDENCIES / POST_INSTALLATION_COMMANDS)
#      apply to ALL four images.
#   2. The PER-IMAGE settings further down (<IMAGE>_SYSTEM_DEPENDENCIES, etc.)
#      let a single image add to — or completely replace — the generic values.
#
# Formatting rules (apply to both generic and per-image values):
#   - Comma-separated list. Surrounding whitespace around each item is trimmed,
#     so "ffmpeg ,  jq" is the same as "ffmpeg,jq".
#   - apt package names are case-sensitive and lowercase by convention. An
#     uppercase package name (e.g. "FFMPEG") is passed through verbatim and will
#     fail the build with "Unable to locate package"; build.sh prints a WARNING
#     when it detects one.

# SYSTEM_DEPENDENCIES
# -------------------
# A comma-separated list of apt packages installed into EVERY built image.
# These are system libraries that some tools/Python packages need at runtime
# (not Python packages themselves).
#
# Example: Install Tesseract OCR and related libraries
# SYSTEM_DEPENDENCIES="tesseract-ocr, tesseract-ocr-eng, libtesseract-dev, libleptonica-dev, pkg-config"
#
# Example: Install multiple system packages
# SYSTEM_DEPENDENCIES="poppler-utils, libgl1, ffmpeg"
#
# Default: empty (no additional packages)
SYSTEM_DEPENDENCIES=""

# POST_INSTALLATION_COMMANDS
# --------------------------
# A comma-separated list of shell commands run (as RUN lines) in EVERY built
# image, after the apt package install. Useful for installing additional tools
# or configuring the environment. Unlike package names, command case is
# preserved (commands and paths are case-sensitive).
#
# Example: Install Playwright dependencies
# POST_INSTALLATION_COMMANDS="playwright install-deps"
#
# Example: Install Bun runtime
# POST_INSTALLATION_COMMANDS="curl -fsSL https://bun.sh/install | bash, cp /root/.bun/bin/bun /usr/local/bin/bun, chmod +x /usr/local/bin/bun"
#
# Example: Multiple commands
# POST_INSTALLATION_COMMANDS="playwright install-deps, ls -la /"
#
# Default: empty (no post-installation commands)
POST_INSTALLATION_COMMANDS=""

# -----------------------------------------------------------------------------
# PER-IMAGE OVERRIDES
# -----------------------------------------------------------------------------
# Each buildable image has its own pair of overrides for both deps and commands,
# named with the image prefix: NIFI_, OPENCODE_, OPENCLAW_, HERMES_.
#
# For each <IMAGE>_<SETTING> there is a matching <IMAGE>_<SETTING>_MODE that
# controls how the per-image value combines with the generic value above:
#
#   _MODE="add"        Install/run the generic value AND the per-image value.
#                      (If the per-image value is empty, only the generic value
#                      is used — i.e. "add nothing extra".)
#
#   _MODE="" (unset)   Same as "add" — the default behavior.
#
#   _MODE="override"   Ignore the generic value entirely; use ONLY the per-image
#                      value. Edge case: if the per-image value is EMPTY and the
#                      mode is "override", then NOTHING is installed/run for that
#                      image — even if the generic value is non-empty. This is
#                      how you opt a single image out of a global dependency.
#
#   _MODE=<anything else>   Treated as "add", but build.sh prints a WARNING so
#                      typos like "addd" aren't silent.
#
# The MODE value is case-insensitive and whitespace-trimmed ("Override" works).
#
# Example — give only Hermes ffmpeg on top of the global deps:
#   HERMES_SYSTEM_DEPENDENCIES="ffmpeg"
#   HERMES_SYSTEM_DEPENDENCIES_MODE="add"
#
# Example — build OpenCode with a custom dep set, ignoring the global one:
#   OPENCODE_SYSTEM_DEPENDENCIES="jq, ripgrep"
#   OPENCODE_SYSTEM_DEPENDENCIES_MODE="override"
#
# Example — keep yt-dlp globally but exclude it from the Hermes image:
#   SYSTEM_DEPENDENCIES="yt-dlp"
#   HERMES_SYSTEM_DEPENDENCIES=""
#   HERMES_SYSTEM_DEPENDENCIES_MODE="override"

# --- NiFi ---
NIFI_SYSTEM_DEPENDENCIES=""
NIFI_SYSTEM_DEPENDENCIES_MODE="add" # add | override
NIFI_POST_INSTALLATION_COMMANDS=""
NIFI_POST_INSTALLATION_COMMANDS_MODE="add" # add | override

# --- OpenCode ---
OPENCODE_SYSTEM_DEPENDENCIES=""
OPENCODE_SYSTEM_DEPENDENCIES_MODE="add" # add | override
OPENCODE_POST_INSTALLATION_COMMANDS=""
OPENCODE_POST_INSTALLATION_COMMANDS_MODE="add" # add | override

# --- OpenClaw ---
OPENCLAW_SYSTEM_DEPENDENCIES=""
OPENCLAW_SYSTEM_DEPENDENCIES_MODE="add" # add | override
OPENCLAW_POST_INSTALLATION_COMMANDS=""
OPENCLAW_POST_INSTALLATION_COMMANDS_MODE="add" # add | override

# --- Hermes ---
HERMES_SYSTEM_DEPENDENCIES=""
HERMES_SYSTEM_DEPENDENCIES_MODE="add" # add | override
HERMES_POST_INSTALLATION_COMMANDS=""
HERMES_POST_INSTALLATION_COMMANDS_MODE="add" # add | override
