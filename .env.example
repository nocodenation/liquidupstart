# =============================================================================
# Liquid Upstart — settings
# =============================================================================
# This file holds all the settings for your installation. The easiest way to
# change anything is the dashboard in your web browser, but you can also edit
# this file by hand if you prefer.
#
# Good news: you can leave almost everything blank. Empty values are either
# filled in automatically or simply leave a feature switched off. Only fill in
# the few things you actually want — for example, an AI key in section 5 or your
# own local AI model in section 6.
# =============================================================================


# =============================================================================
# 1. NETWORKING
# =============================================================================
# Which ports the apps are served on in your browser. Leave both blank and the
# installer picks free ones for you — it prints the final web addresses when it
# starts. Only set these if you need specific port numbers.
SYSTEM_HTTP_PORT=
SYSTEM_HTTPS_PORT=


# =============================================================================
# 2. SERVICE SECRETS & CREDENTIALS - AUTOGENERATED ONCE IF VALUES ARE EMPTY
# =============================================================================

# Internal passwords the apps use to talk to each other. Leave them ALL blank —
# secure random values are created for you on the first save. You normally never
# need to look at or change anything in this section.

# --- Main database & API ---
DATABASE_PASSWORD=
# Leave blank. (The odd spelling here is intentional — please don't change it.)
POSTGREST_JWT_SECTET=

# --- pgAdmin (database admin tool) ---
PGADMIN_DATABASE_PASSWORD=

# --- OpenProject (project management) ---
OPENPROJECT_DATABASE_PASSWORD=
OPENPROJECT_SECRET_KEY_BASE=

# --- NextCloud (files & collaboration) ---
NEXTCLOUD_DATABASE_PASSWORD=
NEXTCLOUD_REDIS_PASSWORD=

# --- Hermes ---
HERMES_API_KEY=

# --- OpenClaw (AI assistant) ---
OPENCLAW_GATEWAY_TOKEN=


# =============================================================================
# 3. SERVICE SECRETS & CREDENTIALS - USER CAN CHANGE ON FIRST RUN
# =============================================================================
# The email address shown for the pgAdmin database tool. You can change it, but
# it isn't used to sign in (that happens automatically), so the default is fine.
PGADMIN_DEFAULT_EMAIL=user@nocodenation.org


# =============================================================================
# 4. SERVICE SECRETS & CREDENTIALS - SCRIPTS GENERATE IT - DO NOT SHOW UI
# =============================================================================
# These are set up automatically by the installer. Please leave them exactly as
# they are.
API_KEY=generate_this_with_shell_script
PGADMIN_DEFAULT_PASSWORD=unused_pgadmin_uses_webserver_auth


# =============================================================================
# 5. LLM PROVIDER API KEYS (shared)
# =============================================================================
# To use a paid AI service, paste your key from that provider below. You only
# need the ones you already have an account with — leave the rest blank to skip
# them. These keys are shared by the AI tools in the stack.
#
# Don't have any keys? That's fine — you can run a free AI model on your own
# computer instead; see section 6.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
# Only needed if your MiniMax account requires a group id.
MINIMAX_GROUP_ID=
ZAI_API_KEY=
AI_GATEWAY_API_KEY=
SYNTHETIC_API_KEY=
TOKENHUB_API_KEY=
LKEAP_API_KEY=


# =============================================================================
# 6. SELF-HOSTED LOCAL LLM
# =============================================================================

# Prefer a free AI model running on your own computer or local network instead
# of a paid service? Point the stack at it here. This works with apps like LM
# Studio or Ollama. Filling this in switches the local model on for both AI
# tools automatically; leave it blank to skip.

# The web address of your local AI server, including its port. For example:
#   http://local_llm:8080      (the name "local_llm" stands in for the IP below)
#   http://192.168.1.50:1234
# Don't add anything after the port number.
LOCAL_LLM_API_BASE=
# The network address (IP) of the computer running that AI server.
LOCAL_LLM_HOST_IP=
# A key for your AI server — only if it needs one. Most home setups (like a
# default LM Studio) don't, so leave this blank.
LOCAL_LLM_API_KEY=


# =============================================================================
# 7. PRIVACY GATEWAY
# =============================================================================

# The Privacy Gateway removes sensitive details — names, passwords, ID numbers — from your
# messages before they're sent to Claude and other cloud AI services, then puts the real
# details back into the reply you get. Off by default. Set to 1 to turn it on; your AI tools
# then send their requests through it automatically.
PRIVACY_GATEWAY_ENABLE=0
# The port number the gateway uses on your machine. Leave as-is.
PRIVACY_GATEWAY_PORT=8080
# The official AI services the gateway passes your cleaned messages on to — Claude, OpenAI,
# and Grok (xAI). Only change these if you're pointing at a different, compatible service.
PRIVACY_GATEWAY_UPSTREAM=https://api.anthropic.com
PRIVACY_GATEWAY_OPENAI_UPSTREAM=https://api.openai.com
PRIVACY_GATEWAY_XAI_UPSTREAM=https://api.x.ai
# How long (in seconds) to wait for the AI service to reply before giving up.
PRIVACY_GATEWAY_REQUEST_TIMEOUT=120
# How much detail to record in the gateway's own logs: INFO, DEBUG, WARNING, or ERROR.
PRIVACY_GATEWAY_LOG_LEVEL=INFO
# Also use your own local AI (set up under the local AI settings above) to catch sensitive
# details that simple word-matching might miss. 0 = off (faster), 1 = on.
PRIVACY_GATEWAY_LOCAL_LLM_ENABLE=0
# Which model on your local AI to use for that extra check. Blank = pick automatically.
PRIVACY_GATEWAY_LOCAL_LLM_MODEL=
# What to do when a message could still hint at who someone is, even after sensitive details
# were removed:
#   off   = don't check (fastest)
#   log   = check and note the risk on the reply, but always send it (default)
#   block = refuse a risky message, so the AI tool gets an error instead of sending it
PRIVACY_GATEWAY_GATE_MODE=log
# Advanced: how cautious that check is (0–1). At or above the first number is treated as low
# risk, at or above the second as medium, below it as high. Lower them to be stricter.
PRIVACY_GATEWAY_SUFFICIENCY_LOW=0.8
PRIVACY_GATEWAY_SUFFICIENCY_MEDIUM=0.5
# When simply hiding a detail isn't enough — say a job title plus a city plus a distinctive
# fact could still point to one person — have your local AI gently reword it while keeping the
# meaning. Off by default. Needs the local AI settings. (Still experimental — not yet applied
# to real messages.)
PRIVACY_GATEWAY_SEMANTIC_ENABLE=0
# Advanced: optionally use separate local models for the rewording and for double-checking it.
# Blank = use your default local model for both.
PRIVACY_GATEWAY_REWRITER_MODEL=
PRIVACY_GATEWAY_JUDGE_MODEL=
# Advanced: how closely a reworded message must match the original to be accepted automatically,
# flagged for a look, or rejected — and how many times to retry. Leave as-is unless you're sure.
PRIVACY_GATEWAY_FAITHFULNESS_ACCEPT=0.85
PRIVACY_GATEWAY_FAITHFULNESS_SURFACE=0.70
PRIVACY_GATEWAY_SEMANTIC_MAX_ROUNDS=5

# The gateway remembers which real detail each stand-in replaced, so it can restore them in the
# reply. That memory is saved and encrypted on your own computer. Leave the key blank to have one
# created for you, or paste your own. The timer (in seconds) forgets old entries; blank = keep them.
PRIVACY_GATEWAY_VAULT_KEY=
PRIVACY_GATEWAY_VAULT_TTL=
# A last safety check before a message leaves your computer: make sure no passwords or keys slipped
# through. 'block' stops the message if one is found; 'off' skips the check.
PRIVACY_GATEWAY_BACKSTOP_MODE=block
# Keep a private record of what kinds of details were hidden (just the categories, never the actual
# values). 1 = on, 0 = off.
PRIVACY_GATEWAY_AUDIT_ENABLE=1


# =============================================================================
# 8. OPENCLAW CONFIGURATION
# =============================================================================
# OpenClaw is the recommended AI assistant. Each option below connects an AI
# service you already pay for. Use 0 for off and 1 for on. You can turn on as
# many as you like and choose which one to use inside OpenClaw. After starting,
# you sign in to each from the dashboard.

# --- Use a Claude (Anthropic) subscription ---
# Turn on (1) to add Claude. Note: this one requires rebuilding the app after.
# When on, Claude models run through your Claude subscription (Claude CLI) and
# any ANTHROPIC_API_KEY above is ignored. Leave off (0) to bill Claude models to
# ANTHROPIC_API_KEY instead.
ENABLE_ANTHROPIC_CLAUDE_CODE=0

# --- Use GitHub Copilot ---
# Turn on (1) to add GitHub Copilot. Sign in from the dashboard when it starts.
ENABLE_GITHUB_COPILOT=0

# --- Use a ChatGPT subscription ---
# Turn on (1) to use your paid ChatGPT plan instead of an OpenAI key. Sign in
# with ChatGPT from the dashboard when it starts — no key needed.
# When on, OpenAI (GPT) chat runs through your ChatGPT/Codex subscription and
# any OPENAI_API_KEY above is ignored for chat. The key is still used for
# embeddings/RAG (the subscription can't embed), so keep it set if you use
# PDF ingest or vector search. Leave off (0) to bill OpenAI chat to the key too.
ENABLE_OPENAI_CODEX=0

# --- Use a Grok (xAI) subscription ---
# Turn on (1) to use your paid SuperGrok or X Premium plan instead of an xAI
# key. Sign in with Grok from the dashboard when it starts — no key needed.
ENABLE_XAI_GROK=0

# ⚠️  Heads-up when the Privacy Gateway is on: if you turn on the Privacy Gateway (section 7)
# together with any of the three subscriptions above (Copilot / ChatGPT / Grok), the gateway
# will clean those services' messages too — no extra setting needed. Doing this with a paid
# subscription likely goes against that provider's terms of service, and they may not allow it.
# Leave the Privacy Gateway off to use these subscriptions normally, without cleaning. Your call.


# =============================================================================
# 9. Liquid AUTHENTICATION
# =============================================================================
# Login for Liquid (the data-flow app). Set a username AND password together to
# choose your own, or leave both blank to have random ones created for you. If
# you set a password, make it at least 12 characters.
LIQUID_USERNAME="liquid"
LIQUID_PASSWORD="liquidpassword"
# Password that protects Liquid's secure-connection certificates. The default is
# fine for most people.
LIQUID_KEYSTORE_PASSWORD=keystorepassword


# =============================================================================
# 10. IMAGE BUILD CONFIGURATION (used by build.sh)
# =============================================================================
#
# ADVANCED — most people can ignore this whole section and leave everything
# blank. It lets you add extra software into the apps when they are built, for
# example a tool that a custom workflow needs.
#
# Two settings below apply to all four built apps (Liquid, OpenCode, OpenClaw,
# Hermes):
#   - SYSTEM_DEPENDENCIES ......... extra system packages to install
#   - POST_INSTALLATION_COMMANDS .. extra setup commands to run afterwards
# Further down, each app has its own versions that can add to — or replace —
# these shared values.
#
# Notes:
#   - Separate multiple items with commas (spaces around them don't matter).
#   - Package names must be lowercase; an uppercase name will fail the build.

# SYSTEM_DEPENDENCIES
# -------------------
# Extra system packages added to every built app. These are background
# components that some tools need in order to run. Leave blank for none.
#
# Example: SYSTEM_DEPENDENCIES="poppler-utils, libgl1, ffmpeg"
SYSTEM_DEPENDENCIES=""

# POST_INSTALLATION_COMMANDS
# --------------------------
# Extra setup commands run in every built app, after the packages above are
# installed. Useful for adding extra tools. Leave blank for none.
#
# Example: POST_INSTALLATION_COMMANDS="playwright install-deps"
POST_INSTALLATION_COMMANDS=""

# -----------------------------------------------------------------------------
# PER-IMAGE OVERRIDES
# -----------------------------------------------------------------------------
# Each app also has its own copies of the two settings above, named with the
# app's prefix: LIQUID_, OPENCODE_, OPENCLAW_, HERMES_. Use these to give just
# one app something extra.
#
# Each one has a matching _MODE that decides how it combines with the shared
# values above:
#   add       (the default) use the shared values AND this app's extra values.
#   override  ignore the shared values and use only this app's values. (Set the
#             value to empty together with override to give this one app nothing
#             at all.)
#
# Example — add ffmpeg to Hermes only, on top of the shared list:
#   HERMES_SYSTEM_DEPENDENCIES="ffmpeg"
#   HERMES_SYSTEM_DEPENDENCIES_MODE="add"
#
# Example — give OpenCode its own list and ignore the shared one:
#   OPENCODE_SYSTEM_DEPENDENCIES="jq, ripgrep"
#   OPENCODE_SYSTEM_DEPENDENCIES_MODE="override"

# --- Liquid ---
LIQUID_SYSTEM_DEPENDENCIES=""
LIQUID_SYSTEM_DEPENDENCIES_MODE="add" # add | override
LIQUID_POST_INSTALLATION_COMMANDS=""
LIQUID_POST_INSTALLATION_COMMANDS_MODE="add" # add | override

# --- OpenCode ---
OPENCODE_SYSTEM_DEPENDENCIES=""
OPENCODE_SYSTEM_DEPENDENCIES_MODE="add" # add | override
OPENCODE_POST_INSTALLATION_COMMANDS=""
OPENCODE_POST_INSTALLATION_COMMANDS_MODE="add" # add | override

# --- OpenClaw ---
OPENCLAW_SYSTEM_DEPENDENCIES=""
OPENCLAW_SYSTEM_DEPENDENCIES_MODE="add" # add | override
OPENCLAW_POST_INSTALLATION_COMMANDS=""
OPENCLAW_POST_INSTALLATION_COMMANDS_MODE="add" # add | override

# --- Hermes ---
HERMES_SYSTEM_DEPENDENCIES=""
HERMES_SYSTEM_DEPENDENCIES_MODE="add" # add | override
HERMES_POST_INSTALLATION_COMMANDS=""
HERMES_POST_INSTALLATION_COMMANDS_MODE="add" # add | override
